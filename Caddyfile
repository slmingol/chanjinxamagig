:80 {
    root * /usr/share/caddy
    file_server
    
    encode gzip
    
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
    
    # Disable caching for HTML and JS files during development
    header /index.html Cache-Control "no-cache, no-store, must-revalidate"
    header /script.js Cache-Control "no-cache, no-store, must-revalidate"
    header /styles.css Cache-Control "no-cache, no-store, must-revalidate"
    
    # Cache images and other static assets
    header /*.png Cache-Control "public, max-age=31536000"
    header /*.json Cache-Control "public, max-age=3600"
    
    log {
        output stdout
        format json
    }
}
